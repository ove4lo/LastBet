  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bba2d67f3d05460439eff8093ae631cf, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::LastBetMiniGameManager
  cardPrefab: {fileID: 8679417842272845759, guid: 95fe4b7df8e6b704bad6686f5f0cd46d, type: 3}
  cardParent: {fileID: 1118318777}
  cardsOnTable: 6
  deckTemplates:
  - symbolType: 1
    symbolSprite: {fileID: 21300000, guid: eea27bea6bf076647afa3a524439ac3b, type: 3}
    title: "\u041F\u0442\u0438\u0446\u0430"
    cardDescription: "\u0421\u0438\u043C\u0432\u043E\u043B \u0441\u0432\u043E\u0431\u043E\u0434\u044B.
      \u042D\u0432\u0435\u043B\u0438\u043D \u0442\u044F\u043D\u0435\u0442\u0441\u044F
      \u043A \u0432\u044B\u0445\u043E\u0434\u0443 \u0438\u0437 \u043A\u043B\u0435\u0442\u043A\u0438,
      \u0434\u0430\u0436\u0435 \u0435\u0441\u043B\u0438 \u043D\u0435 \u0437\u043D\u0430\u0435\u0442,
      \u0447\u0442\u043E \u0436\u0434\u0451\u0442 \u0437\u0430 \u0434\u0432\u0435\u0440\u044C\u044E."
    victorLine: "\u041F\u0442\u0438\u0446\u0430 \u0432\u0441\u0435\u0433\u0434\u0430
      \u043C\u0435\u0447\u0442\u0430\u0435\u0442 \u043E \u043D\u0435\u0431\u0435.
      \u041F\u043E\u043A\u0430 \u043D\u0435 \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442,
      \u043A\u0442\u043E \u0435\u0451 \u043A\u043E\u0440\u043C\u0438\u0442."
    freedomValue: 1
    cageValue: 0
    truthValue: 0
    pressureValue: 0
  - symbolType: 2
    symbolSprite: {fileID: 21300000, guid: 921efb009616d644a94164f8cb3aca77, type: 3}
    title: "\u041A\u043B\u0435\u0442\u043A\u0430"
    cardDescription: "\u0421\u0438\u043C\u0432\u043E\u043B \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044F
      \u0438 \u043F\u0440\u0438\u0432\u044B\u0447\u043D\u043E\u0439 \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438.
      \u041A\u043B\u0435\u0442\u043A\u0430 \u043A\u0430\u0436\u0435\u0442\u0441\u044F
      \u0437\u0430\u0449\u0438\u0442\u043E\u0439, \u043F\u043E\u043A\u0430 \u042D\u0432\u0435\u043B\u0438\u043D
      \u0437\u0430\u0431\u044B\u0432\u0430\u0435\u0442, \u0447\u0442\u043E \u0434\u0432\u0435\u0440\u044C
      \u0437\u0430\u043A\u0440\u044B\u0442\u0430 \u043D\u0435 \u0435\u044E."
    victorLine: "\u0414\u043E\u043C \u0443\u0437\u043D\u0430\u0451\u0442 \u0441\u0432\u043E\u0438\u0445.
      \u0414\u0430\u0436\u0435 \u0435\u0441\u043B\u0438 \u043E\u043D\u0438 \u0434\u0435\u043B\u0430\u044E\u0442
      \u0432\u0438\u0434, \u0447\u0442\u043E \u0445\u043E\u0442\u044F\u0442 \u0443\u0439\u0442\u0438."
    freedomValue: 0
    cageValue: 1
    truthValue: 0
    pressureValue: 0
  - symbolType: 3
    symbolSprite: {fileID: 21300000, guid: 3b794c10062d3dd479e9a9d694e94b95, type: 3}
    title: "\u041A\u043E\u043A\u0442\u0435\u0439\u043B\u044C"
    cardDescription: "\u0421\u0438\u043C\u0432\u043E\u043B \u043F\u043E\u0434\u0447\u0438\u043D\u0435\u043D\u0438\u044F
      \u0447\u0435\u0440\u0435\u0437 \u0437\u0430\u0431\u043E\u0442\u0443. \u041D\u0430\u043F\u0438\u0442\u043E\u043A
      \u043D\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442, \u043A\u0430\u043A
      \u043B\u0435\u0433\u043A\u043E \u0447\u0443\u0436\u0430\u044F \u0432\u043E\u043B\u044F
      \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u0441\u043F\u0440\u044F\u0442\u0430\u043D\u0430
      \u043F\u043E\u0434 \u0432\u0438\u0434\u043E\u043C \u0437\u0430\u0449\u0438\u0442\u044B."
    victorLine: "\u0417\u0430\u0431\u043E\u0442\u0430 \u0431\u044B\u0432\u0430\u0435\u0442
      \u0433\u043E\u0440\u044C\u043A\u043E\u0439, \u0434\u043E\u0440\u043E\u0433\u0430\u044F.
      \u041D\u043E \u0431\u0435\u0437 \u043D\u0435\u0451 \u0442\u044B \u0431\u044B
      \u0434\u0430\u0432\u043D\u043E \u0441\u043E\u0440\u0432\u0430\u043B\u0430\u0441\u044C."
    freedomValue: 0
    cageValue: 1
    truthValue: 0
    pressureValue: 0
  - symbolType: 4
    symbolSprite: {fileID: 21300000, guid: 29486423c470ad54c8e64bf7481ff167, type: 3}
    title: "\u0413\u043B\u0430\u0437"
    cardDescription: "\u0421\u0438\u043C\u0432\u043E\u043B \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F
      \u0438 \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044F. \u042D\u0432\u0435\u043B\u0438\u043D
      \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442 \u0432\u0438\u0434\u0435\u0442\u044C
      \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u0442\u0440\u0430\u0445,
      \u043D\u043E \u0438 \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E
      \u043B\u043E\u0432\u0443\u0448\u043A\u0438."
    victorLine: "\u041E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u0435\u0435, \u0434\u043E\u0440\u043E\u0433\u0430\u044F.
      \u041D\u0435 \u0432\u0441\u0435 \u0438\u0441\u0442\u0438\u043D\u044B \u0441\u0442\u043E\u0438\u0442
      \u043F\u0440\u043E\u0438\u0437\u043D\u043E\u0441\u0438\u0442\u044C \u043F\u0440\u0438
      \u043F\u0443\u0431\u043B\u0438\u043A\u0435."
    freedomValue: 0
    cageValue: 0
    truthValue: 1
    pressureValue: 0
  - symbolType: 5
    symbolSprite: {fileID: 21300000, guid: ee4371ae11fe19b47bf2de41f976deae, type: 3}
    title: "\u041C\u0438\u043A\u0440\u043E\u0444\u043E\u043D"
    cardDescription: "\u0421\u0438\u043C\u0432\u043E\u043B \u0433\u043E\u043B\u043E\u0441\u0430.
      \u041F\u0440\u0430\u0432\u0434\u0430 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F
      \u043E\u043F\u0430\u0441\u043D\u043E\u0439 \u0442\u043E\u043B\u044C\u043A\u043E
      \u0442\u043E\u0433\u0434\u0430, \u043A\u043E\u0433\u0434\u0430 \u0435\u0451
      \u043C\u043E\u0436\u043D\u043E \u0443\u0441\u043B\u044B\u0448\u0430\u0442\u044C
      \u0441\u043E \u0441\u0446\u0435\u043D\u044B."
    victorLine: "\u0413\u043E\u043B\u043E\u0441 \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u0435\u043D,
      \u043F\u043E\u043A\u0430 \u043F\u043E\u0451\u0442 \u043D\u0443\u0436\u043D\u044B\u0435
      \u0441\u043B\u043E\u0432\u0430."
    freedomValue: 0
    cageValue: 0
    truthValue: 1
    pressureValue: 0
  - symbolType: 6
    symbolSprite: {fileID: 21300000, guid: 754e0243d6d983f4eab17caf680a7bb4, type: 3}
    title: "\u0414\u0436\u043E\u043A\u0435\u0440"
    cardDescription: "\u0421\u0438\u043C\u0432\u043E\u043B \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u044F
      \u0412\u0438\u043A\u0442\u043E\u0440\u0430. \u0420\u0430\u0441\u043A\u043B\u0430\u0434
      \u0441\u0431\u0438\u0432\u0430\u0435\u0442\u0441\u044F, \u0441\u0442\u0440\u0430\u0445
      \u0443\u0441\u0438\u043B\u0438\u0432\u0430\u0435\u0442\u0441\u044F, \u0438
      \u042D\u0432\u0435\u043B\u0438\u043D \u0442\u0440\u0443\u0434\u043D\u0435\u0435
      \u0443\u0434\u0435\u0440\u0436\u0430\u0442\u044C \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435
      \u0440\u0435\u0448\u0435\u043D\u0438\u0435."
    victorLine: "\u0412\u043E\u0442 \u0432\u0438\u0434\u0438\u0448\u044C? \u0414\u0430\u0436\u0435
      \u0441\u0443\u0434\u044C\u0431\u0430 \u043F\u0440\u043E\u0442\u0438\u0432\u0438\u0442\u0441\u044F
      \u0442\u0432\u043E\u0435\u0439 \u0434\u0435\u0440\u0437\u043E\u0441\u0442\u0438."
    freedomValue: 0
    cageValue: 0
    truthValue: 0
    pressureValue: 1
