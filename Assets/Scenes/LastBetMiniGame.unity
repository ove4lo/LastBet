--- !u!114 &1873445769
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1873445767}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 325543313eb9049acb6fbebc7dff3a77, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SentryToolkit.UITutorialManager
  overlayPanel: {fileID: 193608696}
  tooltipPrefab: {fileID: 2787124142188344136, guid: 61e51519434a74ddb93f5103947e9cd6, type: 3}
  TutorialSequences:
  - sequenceName: 7
    steps:
    - focusButtonID: 1
      message: "\xAB\u041A\u0430\u0440\u0442\u044B \u043B\u0435\u0436\u0430\u0442
        \u0440\u0443\u0431\u0430\u0448\u043A\u043E\u0439 \u0432\u043D\u0438\u0437.\r\n\u042D\u0432\u0435\u043B\u0438\u043D
        \u043D\u0435 \u0437\u043D\u0430\u0435\u0442 \u0447\u0442\u043E \u043F\u043E\u0434
        \u043A\u0430\u0436\u0434\u043E\u0439 - \u0443\u043B\u0438\u043A\u0430, \u043B\u043E\u0436\u043D\u044B\u0439
        \u0441\u043B\u0435\u0434 \u0438\u043B\u0438 \u043F\u043E\u043C\u0435\u0445\u0430.\r\n\u041E\u0442\u043A\u0440\u044B\u0432\u0430\u0439
        \u043F\u043E \u043E\u0434\u043D\u043E\u0439.\xBB"
      OnStepCompleted:
        m_PersistentCalls:
          m_Calls: []
    - focusButtonID: 4
      message: "\xAB\u042D\u0442\u0430 \u043A\u043D\u043E\u043F\u043A\u0430 \u043F\u0435\u0440\u0435\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u0435\u0442
        \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0443\u044E \u043A\u0430\u0440\u0442\u0443.\r\n\u0427\u0438\u0442\u0430\u0439
        \u0432\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u043E - \u043A\u0430\u0436\u0434\u0430\u044F
        \u0434\u0435\u0442\u0430\u043B\u044C \u043C\u043E\u0436\u0435\u0442 \u0443\u043A\u0430\u0437\u0430\u0442\u044C\r\n\u043D\u0430
        \u043D\u0443\u0436\u043D\u043E\u0433\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430.\xBB"
      OnStepCompleted:
        m_PersistentCalls:
          m_Calls: []
    - focusButtonID: 3
      message: "\xAB\u041D\u0430\u0439\u0434\u0435\u043D\u043D\u044B\u0435 \u0441\u043B\u0435\u0434\u044B
        \u043E\u0441\u0435\u0434\u0430\u044E\u0442 \u0437\u0434\u0435\u0441\u044C.\r\n\u041D\u0430\u0432\u0435\u0434\u0438
        \u043D\u0430 \u0443\u043B\u0438\u043A\u0443 \u0447\u0442\u043E\u0431\u044B
        \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u0442\u044C \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0435\u0435.\r\n\u0414\u0436\u043E\u043A\u0435\u0440
        \u043C\u043E\u0436\u0435\u0442 \u0441\u0434\u0435\u043B\u0430\u0442\u044C
        \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439 \u0441\u043B\u0435\u0434
        \u043D\u0435\u043D\u0430\u0434\u0451\u0436\u043D\u044B\u043C.\xBB"
      OnStepCompleted:
        m_PersistentCalls:
          m_Calls: []
    - focusButtonID: 2
      message: "\xAB\u041A\u0430\u0431\u0430\u0440\u0435 \u0441\u043B\u0435\u0434\u0438\u0442
        \u0437\u0430 \u042D\u0432\u0435\u043B\u0438\u043D.\r\n\u0415\u0441\u043B\u0438
        \u044D\u0442\u043E\u0442 \u0441\u0447\u0451\u0442\u0447\u0438\u043A \u0437\u0430\u043F\u043E\u043B\u043D\u0438\u0442\u0441\u044F
        \u2014 \u043F\u0430\u0440\u0442\u0438\u044F \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u0442\u0441\u044F\r\n\u0440\u0430\u043D\u044C\u0448\u0435
        \u0447\u0435\u043C \u043E\u043D\u0430 \u0443\u0441\u043F\u0435\u0435\u0442
        \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u0432\u044B\u0432\u043E\u0434.\xBB"
      OnStepCompleted:
        m_PersistentCalls:
          m_Calls: []
    - focusButtonID: 5
      message: "\xAB\u041A\u043E\u0433\u0434\u0430 \u0441\u043B\u0435\u0434\u043E\u0432
        \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E \u2014 \u043A\u043D\u043E\u043F\u043A\u0430
        \u0441\u0442\u0430\u043D\u0435\u0442 \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0439.\r\n\u041D\u0435
        \u043D\u0443\u0436\u043D\u043E \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0442\u044C
        \u0432\u0441\u0435 \u043A\u0430\u0440\u0442\u044B.\r\n\u0418\u043D\u043E\u0433\u0434\u0430
        \u0432\u043E\u0432\u0440\u0435\u043C\u044F \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C\u0441\u044F
        \u0432\u0430\u0436\u043D\u0435\u0435 \u0447\u0435\u043C \u0437\u043D\u0430\u0442\u044C
        \u0432\u0441\u0451.\xBB"
      OnStepCompleted:
        m_PersistentCalls:
          m_Calls: []
  tooltipOffset: 28
  screenPadding: {x: 28, y: 28}
  testSequenceID: 0
  testButtonID: 0
  currentStepIndex: 0
