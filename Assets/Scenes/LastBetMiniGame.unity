  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::LastBetMiniGameManager
  cardPrefab: {fileID: 7766817848470882460, guid: df41a2b8600e74948af9a448f36c48d5, type: 3}
  cardParent: {fileID: 271727058}
  cardsOnTable: 6
  deckTemplates:
  - cardType: 0
    storyClue: 1
    informationValue: 1
    suspicionValue: 0
    clueSprite: {fileID: 21300000, guid: 2bc92998c1aa12d41be33fab88af532d, type: 3}
    title: "\u0417\u0410\u0416\u0418\u0413\u0410\u041B\u041A\u0410"
    cardDescription: "\u0427\u0443\u0436\u0430\u044F \u0432\u0435\u0449\u044C \u0443
      \u0441\u043B\u0443\u0436\u0435\u0431\u043D\u043E\u0433\u043E \u0432\u0445\u043E\u0434\u0430"
    evidencePanelDescription: "\u0422\u044F\u0436\u0451\u043B\u0430\u044F \u043C\u0435\u0442\u0430\u043B\u043B\u0438\u0447\u0435\u0441\u043A\u0430\u044F
      \u0437\u0430\u0436\u0438\u0433\u0430\u043B\u043A\u0430 \u0441 \u043F\u043E\u0442\u0451\u0440\u0442\u043E\u0439
      \u0433\u0440\u0430\u0432\u0438\u0440\u043E\u0432\u043A\u043E\u0439. \u0415\u0451
      \u043D\u0430\u0448\u043B\u0438 \u0432\u043E\u0437\u043B\u0435 \u0434\u0432\u0435\u0440\u0438,
      \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
      \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u043B \u043A\u0430\u0431\u0430\u0440\u0435."
    croupierLine: "\u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u0430\u044F \u043D\u0430\u0445\u043E\u0434\u043A\u0430.
      \u041D\u043E \u0432\u0435\u0449\u044C \u0443 \u0434\u0432\u0435\u0440\u0438
      \u0435\u0449\u0451 \u043D\u0435 \u0433\u043E\u0432\u043E\u0440\u0438\u0442,
      \u043A\u0442\u043E \u0435\u0451 \u043E\u0441\u0442\u0430\u0432\u0438\u043B."
  - cardType: 0
    storyClue: 2
    informationValue: 1
    suspicionValue: 0
    clueSprite: {fileID: 21300000, guid: 3b6b72e6aec324f4c886b053cfd1923b, type: 3}
    title: "VIP-\u0411\u0418\u041B\u0415\u0422"
    cardDescription: "\u0421\u043B\u0435\u0434 \u0437\u0430\u043A\u0440\u044B\u0442\u043E\u0439
      \u043B\u043E\u0436\u0438"
    evidencePanelDescription: "\u0411\u0438\u043B\u0435\u0442 \u0438\u0437 \u0437\u0430\u043A\u0440\u044B\u0442\u043E\u0439
      \u043B\u043E\u0436\u0438 \u0432\u0442\u043E\u0440\u043E\u0433\u043E \u044D\u0442\u0430\u0436\u0430.
      \u041D\u0430 \u043E\u0431\u043E\u0440\u043E\u0442\u0435 \u043E\u0441\u0442\u0430\u043B\u0430\u0441\u044C
      \u0435\u0434\u0432\u0430 \u0437\u0430\u043C\u0435\u0442\u043D\u0430\u044F \u043F\u043E\u043C\u0435\u0442\u043A\u0430
      \u043A\u0430\u0440\u0430\u043D\u0434\u0430\u0448\u043E\u043C."
    croupierLine: "\u0417\u0430\u043A\u0440\u044B\u0442\u0430\u044F \u043B\u043E\u0436\u0430
      \u043C\u043D\u043E\u0433\u043E\u0435 \u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442.
      \u0418\u043D\u043E\u0433\u0434\u0430 \u0441\u043B\u0438\u0448\u043A\u043E\u043C
      \u043C\u043D\u043E\u0433\u043E\u0435."
  - cardType: 0
    storyClue: 3
    informationValue: 1
    suspicionValue: 0
    clueSprite: {fileID: 21300000, guid: 20431f162f035aa4eb4e2faf80eb403e, type: 3}
    title: "\u0417\u0410\u041F\u0418\u0421\u041A\u0410"
    cardDescription: "\u0424\u0440\u0430\u0437\u0430 \u0431\u0435\u0437 \u043F\u043E\u0434\u043F\u0438\u0441\u0438"
    evidencePanelDescription: "\xAB\u041F\u043E\u0441\u043B\u0435 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0439
      \u0441\u0442\u0430\u0432\u043A\u0438 \u0434\u0432\u0435\u0440\u044C \u0431\u0443\u0434\u0435\u0442
      \u043E\u0442\u043A\u0440\u044B\u0442\u0430\xBB. \u0417\u0430\u043F\u0438\u0441\u043A\u0430
      \u0441\u043B\u043E\u0436\u0435\u043D\u0430 \u0441\u043B\u0438\u0448\u043A\u043E\u043C
      \u0430\u043A\u043A\u0443\u0440\u0430\u0442\u043D\u043E, \u0431\u0443\u0434\u0442\u043E
      \u0435\u0451 \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u043B\u0438
      \u0437\u0430\u0440\u0430\u043D\u0435\u0435."
    croupierLine: "\u0411\u0443\u043C\u0430\u0433\u0430 \u0442\u0435\u0440\u043F\u0438\u0442
      \u043B\u044E\u0431\u044B\u0435 \u0441\u043B\u043E\u0432\u0430. \u041F\u043E\u0434\u043F\u0438\u0441\u044C
      \u043E\u0431\u044B\u0447\u043D\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u0442
      \u0431\u043E\u043B\u044C\u0448\u0435."
  - cardType: 0
    storyClue: 4
    informationValue: 1
    suspicionValue: 1
    clueSprite: {fileID: 21300000, guid: 31a66813e9fc60b428f17b25b89f2154, type: 3}
    title: "\u041C\u0410\u0421\u041A\u0410"
    cardDescription: "\u0421\u043D\u044F\u0442\u0430 \u0441\u043B\u0438\u0448\u043A\u043E\u043C
      \u043F\u043E\u0441\u043F\u0435\u0448\u043D\u043E"
    evidencePanelDescription: "\u0427\u0435\u0440\u043D\u0430\u044F \u0441\u0446\u0435\u043D\u0438\u0447\u0435\u0441\u043A\u0430\u044F
      \u043C\u0430\u0441\u043A\u0430 \u0441 \u043D\u0430\u0434\u043E\u0440\u0432\u0430\u043D\u043D\u043E\u0439
      \u043B\u0435\u043D\u0442\u043E\u0439. \u041D\u0430 \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0435\u0439
      \u0441\u0442\u043E\u0440\u043E\u043D\u0435 \u043E\u0441\u0442\u0430\u043B\u0441\u044F
      \u0441\u043B\u0435\u0434 \u0433\u0440\u0438\u043C\u0430."
    croupierLine: "\u041C\u0430\u0441\u043A\u0430 \u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442
      \u043B\u0438\u0446\u043E, \u043D\u043E \u0440\u0435\u0434\u043A\u043E \u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442
      \u0441\u043F\u0435\u0448\u043A\u0443."
  - cardType: 3
    storyClue: 5
    informationValue: 1
    suspicionValue: 0
    clueSprite: {fileID: 21300000, guid: 31a66813e9fc60b428f17b25b89f2154, type: 3}
    title: "\u0417\u0410\u0412\u042F\u0417\u041A\u0410"
    cardDescription: "\u0421\u043B\u0435\u0434 \u0442\u043A\u0430\u043D\u0438 \u0438
      \u0433\u0440\u0438\u043C\u0430"
    evidencePanelDescription: "\u0422\u043E\u043D\u043A\u0430\u044F \u043B\u0435\u043D\u0442\u0430
      \u043F\u0440\u043E\u043F\u0438\u0442\u0430\u043D\u0430 \u0437\u0430\u043F\u0430\u0445\u043E\u043C
      \u0434\u0443\u0445\u043E\u0432 \u0438 \u0442\u0435\u0430\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
      \u0433\u0440\u0438\u043C\u0430. \u041F\u043E\u0445\u043E\u0436\u0443\u044E
      \u0442\u043A\u0430\u043D\u044C \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442
      \u0437\u0430 \u0441\u0446\u0435\u043D\u043E\u0439."
    croupierLine: "\u0417\u0430 \u0441\u0446\u0435\u043D\u043E\u0439 \u0432\u0441\u0435
      \u043F\u0430\u0445\u043D\u0435\u0442 \u0433\u0440\u0438\u043C\u043E\u043C.
      \u041D\u043E \u043D\u0435 \u043A\u0430\u0436\u0434\u044B\u0439 \u0441\u043B\u0435\u0434
      \u0432\u0435\u0434\u0451\u0442 \u043A \u0432\u0440\u0430\u0433\u0443."
  - cardType: 2
    storyClue: 10
    informationValue: 1
    suspicionValue: 1
    clueSprite: {fileID: 21300000, guid: 20431f162f035aa4eb4e2faf80eb403e, type: 3}
    title: "\u0421\u0422\u0410\u0412\u041A\u0418"
    cardDescription: "\u041F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
      \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0430"
    evidencePanelDescription: "\u041A\u0442\u043E-\u0442\u043E \u0438\u0441\u043F\u0440\u0430\u0432\u0438\u043B
      \u043F\u043E\u0440\u044F\u0434\u043E\u043A \u043A\u0430\u0440\u0442\u043E\u0447\u043D\u044B\u0445
      \u0441\u0442\u0430\u0432\u043E\u043A \u043F\u0440\u044F\u043C\u043E \u043F\u0435\u0440\u0435\u0434
      \u043D\u0430\u0447\u0430\u043B\u043E\u043C \u0438\u0433\u0440\u044B. \u0418\u0441\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F
      \u0441\u0434\u0435\u043B\u0430\u043D\u044B \u0443\u0432\u0435\u0440\u0435\u043D\u043D\u043E\u0439
      \u0440\u0443\u043A\u043E\u0439."
    croupierLine: "\u0412 \u0441\u0442\u0430\u0432\u043A\u0430\u0445 \u043D\u0435\u0442
      \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E\u0441\u0442\u0435\u0439. \u0415\u0441\u0442\u044C
      \u0442\u043E\u043B\u044C\u043A\u043E \u0442\u0435, \u043A\u0442\u043E \u0443\u043C\u0435\u0435\u0442
      \u0436\u0434\u0430\u0442\u044C."
  - cardType: 0
    storyClue: 6
    informationValue: 1
    suspicionValue: 0
    clueSprite: {fileID: 21300000, guid: 20431f162f035aa4eb4e2faf80eb403e, type: 3}
    title: "\u041F\u041E\u041C\u0415\u0422\u041A\u0410"
    cardDescription: "\u0417\u043D\u0430\u043A \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u043B\u0430"
    evidencePanelDescription: "\u041D\u0435\u0431\u043E\u043B\u044C\u0448\u043E\u0439
      \u0437\u043D\u0430\u043A \u043D\u0430 \u043F\u043E\u043B\u044F\u0445 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430
      \u0441\u043E\u0432\u043F\u0430\u0434\u0430\u0435\u0442 \u0441 \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u043C\u0438
      \u043E\u0442\u043C\u0435\u0442\u043A\u0430\u043C\u0438 \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u043B\u0430
      \u043A\u0430\u0431\u0430\u0440\u0435."
    croupierLine: "\u041F\u0435\u0440\u0441\u043E\u043D\u0430\u043B \u0432\u0441\u0435\u0433\u0434\u0430
      \u0437\u043D\u0430\u0435\u0442 \u0431\u043E\u043B\u044C\u0448\u0435 \u0433\u043E\u0441\u0442\u0435\u0439.
      \u041D\u043E \u043D\u0435 \u0432\u0441\u0435\u0433\u0434\u0430 \u0433\u043E\u0432\u043E\u0440\u0438\u0442
      \u043F\u0440\u0430\u0432\u0434\u0443."
  - cardType: 0
    storyClue: 7
    informationValue: 1
    suspicionValue: 0
    clueSprite: {fileID: 21300000, guid: 3b6b72e6aec324f4c886b053cfd1923b, type: 3}
    title: "\u041A\u041E\u0420\u0418\u0414\u041E\u0420"
    cardDescription: "\u041C\u0430\u0440\u0448\u0440\u0443\u0442 \u0437\u0430 \u043A\u0443\u043B\u0438\u0441\u044B"
    evidencePanelDescription: "\u041D\u0430 \u0441\u0445\u0435\u043C\u0435 \u043E\u0442\u043C\u0435\u0447\u0435\u043D
      \u0441\u043B\u0443\u0436\u0435\u0431\u043D\u044B\u0439 \u043F\u0440\u043E\u0445\u043E\u0434,
      \u0432\u0435\u0434\u0443\u0449\u0438\u0439 \u043C\u0438\u043C\u043E \u0441\u0446\u0435\u043D\u044B
      \u0438 VIP-\u043A\u043E\u043C\u043D\u0430\u0442. \u041E\u0431\u044B\u0447\u043D\u044B\u0435
      \u0433\u043E\u0441\u0442\u0438 \u043E \u043D\u0451\u043C \u043D\u0435 \u0437\u043D\u0430\u044E\u0442."
    croupierLine: "\u0414\u0432\u0435\u0440\u0438 \u0434\u043B\u044F \u0433\u043E\u0441\u0442\u0435\u0439
      \u0438 \u0434\u0432\u0435\u0440\u0438 \u0434\u043B\u044F \u0441\u0432\u043E\u0438\u0445
      \u0440\u0435\u0434\u043A\u043E \u0432\u0435\u0434\u0443\u0442 \u0432 \u043E\u0434\u043D\u043E
      \u043C\u0435\u0441\u0442\u043E."
